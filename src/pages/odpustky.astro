<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generátor odpustků</title>
</head>
<body>
    <header>
        <h1>Generátor odpustků na A4</h1>
        <p>Vygenerujte a vytiskněte malé odpustky</p>
    </header>
    
    <main>
        <div class="form-container">
            <form id="odpustkyForm">
                <div class="form-group">
                    <label for="name">Jméno učitele</label>
                    <input type="text" placeholder="Jan Janů" id="name" required>
                </div>

                <div class="form-group">
                    <label for="number">Počet odpustků</label>
                    <input type="number" placeholder="100" id="number" min="1" max="999" value="10" required>
                </div>

                <p>
                    Na jednu A4 se vejde 18 odpustků (3 sloupce x 8 řádků). Pokud zadáte více než 24, budou vytvořeny další stránky. Každý odpustek bude mít unikátní ID pro snadnou identifikaci.
                </p>

                <div class="form-group">
                    <label for="type">Typ odpustku</label>
                    <input type="text" placeholder="např. Zkoušení, Domácí úkol, Soutěž..." id="type" required>
                </div>

                <div class="form-group">
                    <label for="description">Popis (volitelné)</label>
                    <textarea placeholder="Další pokyny nebo popis..." id="description" rows="2"></textarea>
                </div>

                <div class="form-group">
                    <label for="classDesignation">Třída (např. 8. G)</label>
                    <input type="text" placeholder="8. G" id="classDesignation" value="8. G">
                </div>

                <div class="form-group">
                    <label for="expiration">Platnost</label>
                    <select id="expiration" required>
                        <option value="calendar">Konec roku 2026</option>
                        <option value="school">Konec školního roku 2025/26</option>
                        <option value="semester">Konec tohoto pololetí</option>
                        <option value="custom">Vlastní datum</option>
                    </select>
                </div>

                <div class="form-group" id="customDateGroup" style="display: none;">
                    <label for="customDate">Vlastní datum platnosti</label>
                    <input type="date" id="customDate">
                </div>

                <div class="form-group signature-group">
                    <label>Podpis (volitelné)</label>
                    <div class="signature-container">
                        <canvas id="signatureCanvas" width="300" height="100"></canvas>
                        <button type="button" id="clearSignature" class="btn-secondary">Smazat podpis</button>
                    </div>
                    <small>Nakreslete podpis pomocí myši nebo prstů</small>
                </div>

                <div class="form-actions">
                    <button type="button" id="generateBtn" class="btn-primary">Vygenerovat a zobrazit náhled</button>
                    <button type="button" id="printBtn" class="btn-success" disabled>Vytisknout na A4</button>
                </div>
            </form>
        </div>
    </main>

    <div id="print-area"></div>
    <div id="valid-odpustky-table"></div>
</body>
</html>

<style is:global>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
        line-height: 1.6;
        background-color: #f5f5f5;
    }

    header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
        text-align: center;
    }

    header h1 {
        margin: 0 0 10px 0;
    }

    header p {
        margin: 0;
        opacity: 0.9;
    }

    main {
        max-width: 800px;
        margin: 20px auto;
        padding: 20px;
    }

    .form-container {
        background: white;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-weight: bold;
        color: #333;
    }

    input[type="text"],
    input[type="number"],
    input[type="date"],
    select,
    textarea {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
        font-family: Arial, sans-serif;
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="date"]:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .signature-group label {
        margin-bottom: 12px;
    }

    .signature-container {
        margin-bottom: 10px;
    }

    #signatureCanvas {
        display: block;
        border: 2px solid #ddd;
        border-radius: 4px;
        background: white;
        cursor: crosshair;
        margin-bottom: 10px;
        max-width: 100%;
        height: auto;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        margin-bottom: 10px;
    }

    .btn-secondary:hover {
        background-color: #5a6268;
    }

    small {
        display: block;
        color: #666;
        margin-top: 5px;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    .btn-primary,
    .btn-success {
        flex: 1;
        padding: 12px 20px;
        border: none;
        border-radius: 4px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-primary {
        background-color: #667eea;
        color: white;
    }

    .btn-primary:hover {
        background-color: #5568d3;
    }

    .btn-success {
        background-color: #28a745;
        color: white;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
    }

    .btn-success:disabled {
        background-color: #ccc;
        cursor: not-allowed;
        opacity: 0.5;
    }

    /* Print Styles */
    @media print {
        body {
            background: white;
        }

        main, header {
            display: none;
        }

        #print-area {
            width: 210mm;
        }

        .page, .validation-page {
            margin: 0 !important;
            padding: 0 !important;
            grid-template-rows: repeat(8, 35mm);
            align-content: start;
            gap: 0 !important;
            page-break-after: always;
            break-after: page;
            border: none !important;
        }

        #valid-odpustky-table {
            page-break-before: always;
            width: 210mm;
            margin: 0 !important;
            padding: 0 !important;
        }

        .validation-page:last-child {
            page-break-after: auto;
            break-after: auto;
        }

        .validation-page h2,
        .validation-page h3,
        .validation-page p {
            margin-bottom: 2mm !important;
        }

        .validation-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 4mm;
        }

        .validation-page table {
            width: 100%;
            table-layout: fixed;
        }

        .validation-page td {
            width: 25%;
            height: 10mm;
            vertical-align: top;
            padding: 2.5mm !important;
        }

        .validation-id {
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.7px;
            line-height: 1.3;
        }

        .validation-signature {
            width: 32mm;
            min-width: 32mm;
            text-align: center;
            font-size: 9px;
            color: #222;
        }

        .validation-signature img {
            width: 100%;
            height: 14mm;
            object-fit: contain;
            border: 1px solid #777;
            border-radius: 2px;
            padding: 1mm !important;
            margin-bottom: 1mm !important;
        }

        .odpustek-footer {
            border-top: 1px dashed black !important;
            padding-top: 1.5mm !important;
            margin-top: 1mm;
        }

        .odpustek-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto auto;
            gap: 2mm;
        }
    }

    /* Screen Preview Styles */
    .page {
        width: 210mm;
        height: 297mm;
        background: white;
        margin: 20px auto;
        padding: 0;
        position: relative;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(8, 35mm);
        gap: 0;
        align-content: start;
    }

    .odpustek {
        border: 2px solid #2c3e50;
        border-radius: 3px;
        padding: 3mm;
        font-size: 9px;
        display: flex;
        flex-direction: column;
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        position: relative;
    }

    .odpustek-header {
        font-weight: bold;
        font-size: 11px;
        color: #2c3e50;
        border-bottom: 2px solid #667eea;
        padding-bottom: 2mm;
        margin-bottom: 2mm;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        justify-content: space-between;
    }

    .odpustek-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto auto;
        gap: 2mm;
    }
    .odpustek-id {
        font-size: 11px;
        font-weight: bold;
        color: #667eea;
        margin-bottom: 1mm;
        font-family: 'Courier New', monospace;
    }

    .odpustek-class {
        font-size: 9px;
        color: #555;
        margin-bottom: 1mm;
        font-weight: 600;
        text-align: right;
    }

    .odpustek-type {
        font-weight: bold;
        color: #2c3e50;
        margin-bottom: 1mm;
        font-size: 10px;
    }

    .odpustek-teacher {
        font-size: 8px;
        color: #555;
        margin-bottom: 1mm;
    }

    .odpustek-description {
        font-size: 8px;
        color: #666;
        margin-bottom: 1mm;
        font-style: italic;
    }

    .odpustek-footer {
        border-top: 1px dashed #ccc;
        padding-top: 1.5mm;
        margin-top: 1mm;
        height: 100%;
        display: flex;
        flex-direction: column;
        gap: 3mm;
    }

    .odpustek-expiration {
        font-size: 8px;
        color: #555;
        font-weight: 500;
    }

    .odpustek-signature {
        position: absolute;
        bottom: 0mm;
        right: 0mm;
        width: 35mm;
        height: 15mm;
    }

    .odpustek-signature img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 2px;
    }

    .signature-preview {
        display: block;
        max-height: 100%;
        max-width: 100%;
    }

    #print-area {
        display: none;
    }

    #print-area.active {
        display: block;
    }

    #valid-odpustky-table {
        display: none;
    }

    #valid-odpustky-table.active {
        display: block;
        max-width: 900px;
        margin: 20px auto;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .validation-page {
        width: 100%;
        background: white;
        padding: 24px;
    }

    .validation-page h2 {
        margin: 0;
        font-size: 20px;
    }

    .validation-page h3 {
        margin: 8px 0 12px 0;
        font-size: 16px;
        color: #2c3e50;
    }

    .validation-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 10px;
    }

    .table-info {
        display: grid;
        grid-template-columns: repeat(2, minmax(200px, 1fr));
        gap: 8px 20px;
        margin-bottom: 16px;
        font-size: 14px;
    }

    .validation-page table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .validation-page td {
        border: 1px solid #ddd;
        width: 25%;
        height: 10mm;
        vertical-align: top;
        padding: 10px;
    }

    .validation-id {
        font-size: 19px;
        font-weight: 700;
        letter-spacing: 0.6px;
        color: #1f2937;
        line-height: 1.3;
    }

    .validation-signature {
        width: 140px;
        min-width: 140px;
        text-align: center;
        font-size: 12px;
        color: #334155;
    }

    .validation-signature img {
        width: 100%;
        height: 54px;
        object-fit: contain;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 4px;
        background: #fff;
        margin-bottom: 6px;
    }

    @media screen and (max-width: 768px) {
        .validation-page-header {
            flex-direction: column;
        }

        .validation-signature {
            width: 100%;
            min-width: 0;
        }

        .table-info {
            grid-template-columns: 1fr;
        }
    }
</style>

<script lang="js">
    // Configuration
    const COLS = 3;
    const ROWS = 8;
    const VALIDATION_COLS = 4;
    const VALIDATION_ROWS = 20;

    // Signature Drawing
    const canvas = document.getElementById('signatureCanvas');
    const ctx = canvas.getContext('2d');
    let isDrawing = false;
    let hasSignature = false;

    // Handle different screen sizes for canvas
    function resizeCanvas() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
    }

    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    canvas.addEventListener('mousedown', startDrawing);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDrawing);
    canvas.addEventListener('mouseout', stopDrawing);

    canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const mouseEvent = new MouseEvent('mousedown', {
            clientX: touch.clientX,
            clientY: touch.clientY
        });
        canvas.dispatchEvent(mouseEvent);
    });

    canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const mouseEvent = new MouseEvent('mousemove', {
            clientX: touch.clientX,
            clientY: touch.clientY
        });
        canvas.dispatchEvent(mouseEvent);
    });

    canvas.addEventListener('touchend', (e) => {
        e.preventDefault();
        const mouseEvent = new MouseEvent('mouseup', {});
        canvas.dispatchEvent(mouseEvent);
    });

    function startDrawing(e) {
        isDrawing = true;
        hasSignature = true;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.beginPath();
        ctx.moveTo(x, y);
    }

    function draw(e) {
        if (!isDrawing) return;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.lineTo(x, y);
        ctx.stroke();
    }

    function stopDrawing() {
        isDrawing = false;
    }

    // Clear signature
    document.getElementById('clearSignature').addEventListener('click', () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasSignature = false;
    });

    // Custom date visibility
    document.getElementById('expiration').addEventListener('change', (e) => {
        const customDateGroup = document.getElementById('customDateGroup');
        customDateGroup.style.display = e.target.value === 'custom' ? 'block' : 'none';
    });

    // Modulo check digit for databseless ID validation
    function computeCheckDigit(typeChar, serialNumber) {
        return ((serialNumber * 7) + typeChar.charCodeAt(0)) % 10;
    }

    // Generate ID in format A123-4
    function generateId(typeChar, serialNumber) {
        const prefix = typeChar.toUpperCase();
        const paddedSerial = serialNumber.toString().padStart(3, '0');
        const checkDigit = computeCheckDigit(prefix, serialNumber);
        return `${prefix}${paddedSerial}-${checkDigit}`;
    }

    function getRandomStartNumber(amount) {
        const maxStart = Math.max(0, 999 - amount);
        return Math.floor(Math.random() * (maxStart + 1));
    }

    // Get expiration text
    function getExpirationText(expType, customDate) {
        const expirations = {
            calendar: 'Platnost: 31.12.2026',
            school: 'Platnost: do konce školního roku',
            semester: 'Platnost: do konce pololetí',
            custom: `Platnost do: ${new Date(customDate).toLocaleDateString('cs-CZ')}`
        };
        return expirations[expType] || '';
    }

    // Generate odpustky
    document.getElementById('generateBtn').addEventListener('click', () => {
        const name = document.getElementById('name').value.trim();
        const number = parseInt(document.getElementById('number').value);
        const type = document.getElementById('type').value.trim();
        const description = document.getElementById('description').value.trim();
        const classDesignation = document.getElementById('classDesignation').value.trim();
        const expiration = document.getElementById('expiration').value;
        const customDate = document.getElementById('customDate').value;
        const signatureData = hasSignature ? canvas.toDataURL() : null;

        if (!name || !type || !number) {
            alert('Vyplňte prosím všechna povinná pole');
            return;
        }

        if (number < 1 || number > 999) {
            alert('Počet odpustků musí být mezi 1 a 999');
            return;
        }

        if (expiration === 'custom' && !customDate) {
            alert('Zadejte prosím vlastní datum platnosti');
            return;
        }

        generateOdpustky(name, number, type, description, classDesignation, expiration, customDate, signatureData);
        document.getElementById('printBtn').disabled = false;
    });

    function generateOdpustky(name, number, type, description, classDesignation, expiration, customDate, signatureData) {
        const validOdpustkyTable = document.getElementById('valid-odpustky-table');
        const printArea = document.getElementById('print-area');
        printArea.innerHTML = '';
        validOdpustkyTable.innerHTML = '';
        printArea.classList.add('active');
        validOdpustkyTable.classList.add('active');

        const expirationText = getExpirationText(expiration, customDate);
        const typeChar = type.charAt(0);
        const startNumber = getRandomStartNumber(number);
        const ids = Array.from({ length: number }, (_, index) => generateId(typeChar, startNumber + index));
        let odpustekCount = 0;
        let currentPage = null;

        for (let i = 0; i < number; i++) {
            if (odpustekCount % (ROWS * COLS) === 0) {
                currentPage = document.createElement('div');
                currentPage.className = 'page';
                printArea.appendChild(currentPage);
                odpustekCount = 0;
            }

            const odpustek = document.createElement('div');
            odpustek.className = 'odpustek';

            const id = ids[i];


            let contentHtml = `
                <div class="odpustek-header"><div>ODPUSTEK</div><div class="odpustek-id">#${id}</div></div>
                <div class="odpustek-content">
            `;
    

            contentHtml += `
                    <div class="odpustek-type">${type}</div>
            `;

            if (classDesignation) {
                contentHtml += `<div class="odpustek-class">vydala třída ${classDesignation}</div>`;
            }

            contentHtml += `<div class="odpustek-teacher">${name}</div>`;
            if (description) {
                contentHtml += `<div class="odpustek-description">${description}</div>`;
            }

            contentHtml += `
                </div>
                <div class="odpustek-footer">
                    <div class="odpustek-expiration">${expirationText}</div>
                </div>
            `;

            if (signatureData) {
                contentHtml += `<div class="odpustek-signature"><img src="${signatureData}" class="signature-preview" alt="Podpis"></div>`;
            }

            odpustek.innerHTML = contentHtml;
            currentPage.appendChild(odpustek);
            odpustekCount++;
        }

        const idsPerValidationPage = VALIDATION_COLS * VALIDATION_ROWS;
        const totalValidationPages = Math.ceil(number / idsPerValidationPage);

        for (let pageIndex = 0; pageIndex < totalValidationPages; pageIndex++) {
            const start = pageIndex * idsPerValidationPage;
            const end = Math.min(start + idsPerValidationPage, number);
            const pageIds = ids.slice(start, end);

            const validationPage = document.createElement('div');
            validationPage.className = 'validation-page';

            const signatureBlock = signatureData
                ? `<div class="validation-signature"><img src="${signatureData}" alt="Podpis učitele"><div>Podpis učitele</div></div>`
                : '';

            validationPage.innerHTML = `
                <div class="validation-page-header">
                    <div>
                        <h2>Seznam ID k ověření</h2>
                        <h3>${name} • ${type} • strana ${pageIndex + 1}/${totalValidationPages}</h3>
                    </div>
                    ${signatureBlock}
                </div>
                <div class="table-info">
                    <div>Počet: <strong>${number}</strong></div>
                    <div>Třída: <strong>${classDesignation || '-'}</strong></div>
                    <div>Start série: <strong>${startNumber.toString().padStart(3, '0')}</strong></div>
                    <div>Popis: <em>${description || 'Žádný'}</em></div>
                    <div>Platnost: <strong>${expirationText}</strong></div>
                    <div>Formát ID: <strong>${typeChar.toUpperCase()}NNN-K</strong> (K = modulo kontrola)</div>
                </div>
            `;

            const tableElement = document.createElement('table');
            validationPage.appendChild(tableElement);

            for (let row = 0; row < VALIDATION_ROWS; row++) {
                const tr = document.createElement('tr');

                for (let col = 0; col < VALIDATION_COLS; col++) {
                    const cellIndex = row * VALIDATION_COLS + col;
                    const id = pageIds[cellIndex] || '';
                    const td = document.createElement('td');

                    if (id) {
                        td.innerHTML = `<div class="validation-id">${id}</div>`;
                    }

                    tr.appendChild(td);
                }

                tableElement.appendChild(tr);
            }

            validOdpustkyTable.appendChild(validationPage);
        }
    }

    // Print
    document.getElementById('printBtn').addEventListener('click', () => {
        window.print();
    });
</script>